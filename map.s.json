{
    ">": "inc %rsi",
    "<": "dec %rsi",
    "+": "incb (%rsi)",
    "-": "decb (%rsi)",
    ".": [  "mov $4,%rax",
            "mov $1,%rdi",
            "mov $1,%rdx",
            "syscall" ],
    ",": [  "mov $3,%rax",
            "mov $0,%rdi",
            "mov $1,%rdx",
            "syscall" ],
    "[": [  "openlabel:",
            "cmpb $0,(%rsi)",
            "jz closelabel" ],
    "]": [  "jmp openlabel", 
            "closelabel:" ]
}
